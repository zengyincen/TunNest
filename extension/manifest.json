{
  "manifest_version": 3,
  "name": "囤囤 TunNest",
  "short_name": "TunNest",
  "version": "1.2.0",
  "description": "同步微信读书、豆瓣、微博与网页到 Notion。",
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "囤囤 TunNest",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "background": { "service_worker": "background.js", "type": "module" },
  "options_page": "options.html",
  "permissions": ["storage", "tabs", "activeTab", "scripting", "contextMenus", "cookies", "alarms"],
  "host_permissions": [
    "https://api.notion.com/*",
    "https://weread.qq.com/*",
    "https://i.weread.qq.com/*",
    "https://*.douban.com/*",
    "https://m.weibo.cn/*",
    "https://weibo.com/*",
    "https://*.workers.dev/*",
    "https://tnlcs.imnotfound.eu.org/*"
  ],
  "commands": {
    "clip-page": {
      "suggested_key": { "default": "Alt+Shift+S", "mac": "MacCtrl+Shift+S" },
      "description": "剪藏当前网页"
    }
  },
  "web_accessible_resources": [{ "resources": ["fonts/*.ttf"], "matches": ["<all_urls>"] }]
}
